emulate -L zsh
__runtime_root="${${(%):-%N}:A:h}"
cd "$__runtime_root" || return 1

if [[ ! -f "$__runtime_root/.venv/bin/activate" ]]; then
  print -u2 "error: .venv is missing. Run ./install.zsh first."
  unset __runtime_root
  return 1
fi

source "$__runtime_root/.venv/bin/activate" || return 1

__runtime_env_names=()

__runtime_source_env_file() {
  local file="$1"
  local line name

  [[ -f "$file" ]] || return 0

  while IFS= read -r line || [[ -n "$line" ]]; do
    if [[ "$line" =~ "^[[:space:]]*export[[:space:]]+([A-Za-z_][A-Za-z0-9_]*)=" ]]; then
      name="$match[1]"
    elif [[ "$line" =~ "^[[:space:]]*([A-Za-z_][A-Za-z0-9_]*)=" ]]; then
      name="$match[1]"
    else
      continue
    fi

    if (( ! ${__runtime_env_names[(Ie)$name]} )); then
      __runtime_env_names+=("$name")
    fi
  done < "$file"

  set -a
  source "$file" || return 1
  set +a
}

__runtime_source_env_file "$__runtime_root/.env.default" || return 1
__runtime_source_env_file "$__runtime_root/.env" || return 1

__runtime_expand_home_path() {
  local name="$1"
  local value="${(P)name-}"

  if [[ "$value" == \~ ]]; then
    export "${name}=$HOME"
  elif [[ "$value" == \~/* ]]; then
    export "${name}=$HOME/${value#\~/}"
  fi
}

__runtime_is_path_var() {
  local name="$1"

  [[ "$name" == *_DIR || "$name" == *_FILE || "$name" == *_PATH ]] && return 0

  case "$name" in
    RAWTEXT_DIR|RAW_TEXT_DIR|VENV_DIR|GENERATOR_OFFLOAD_DIR|EVAL_PROMPTS|SYSTEM_PROMPT_FILE)
      return 0
      ;;
    *)
      return 1
      ;;
  esac
}

for __runtime_env_name in "${__runtime_env_names[@]}"; do
  if __runtime_is_path_var "$__runtime_env_name"; then
    __runtime_expand_home_path "$__runtime_env_name"
  fi
done

if [[ -z "${RAWTEXT_DIR:-}" && -n "${RAW_TEXT_DIR:-}" ]]; then
  export RAWTEXT_DIR="$RAW_TEXT_DIR"
fi
if [[ -z "${RAW_TEXT_DIR:-}" && -n "${RAWTEXT_DIR:-}" ]]; then
  export RAW_TEXT_DIR="$RAWTEXT_DIR"
fi

path=("$__runtime_root/.venv/bin" ${path:#"$__runtime_root/.venv/bin"})
export PATH
rehash 2>/dev/null || true

echo
echo "Runtime ready:"
echo "  python: $(command -v python)"
echo "  version: $(python --version 2>&1)"
for __runtime_env_name in "${__runtime_env_names[@]}"; do
  echo "  ${__runtime_env_name}: ${(P)__runtime_env_name:-<unset>}"
done

unset __runtime_root __runtime_env_name __runtime_env_names
unfunction __runtime_source_env_file __runtime_expand_home_path __runtime_is_path_var 2>/dev/null || true
