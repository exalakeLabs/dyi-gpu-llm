## GPU ENGINE - AMD specific
export HSA_OVERRIDE_GFX_VERSION="11.0.0"
export PYTORCH_CUDA_ALLOC_CONF="expandable_segments:True,max_split_size_mb:128"
export PYTORCH_ALLOC_CONF="${PYTORCH_CUDA_ALLOC_CONF}"

## Dataset directories (absolute, or relative to repo root)
export RAWTEXT_DIR="/datasets/raw-text"
export PDF_DIR="/datasets/pdfs"

## Corpus / pipeline directories (absolute, or relative to repo root)
export PREPARED_DIR="/datasets/model_root/prepared"
export RAG_DIR="/datasets/model_root/rag"
export CORPUS_DIR="/datasets/model_root/corpus"

#MODELS
export EMBED_MODEL="BAAI/bge-base-en-v1.5"
export RERANKER_MODEL="BAAI/bge-reranker-v2-m3"
export GENERATOR_MODEL="Qwen/Qwen2.5-3B-Instruct"
export BASE_MODEL=${GENERATOR_MODEL}

#RAG parameters
export OVERLAP_CHARS="250"
export CHUNK_SIZE_CHARS="1800"
export BATCH_SIZE="32"

#LoRA training parameters
export RETRIEVE_K="24"
export MAX_NEW_TOKENS="128"

#Training parameters
export TRAIN_FILE=${CORPUS_DIR}/train.jsonl
export LORA_DIR="/datasets/model_root/model/lora"
export ADAPTER_DIR=${LORA_DIR}/final
export DEFAULT_MODEL=${BASE_MODEL}
export DEFAULT_MODEL_PATH="/datasets/model_root/model"
export DEFAULT_BACKEND="cuda:0"
export DEFAULT_TEXT_DIR=${PREPARED_DIR}
export DEFAULT_CORPUS_DIR=${CORPUS_DIR}
export DEFAULT_TRAIN_FILE="train.jsonl"
export DEFAULT_EVAL_FILE="eval.jsonl"
export EVAL_PROMPTS="eval_prompts.txt"
export DEFAULT_OUTPUT_DIR="/datasets/model_root/model/output_partial"
export DEFAULT_MAX_LENGTH="512"
export DEFAULT_SEQ_LEN="256"
export DEFAULT_MAX_TRAIN_TOKENS="256"
export DEFAULT_DATASET_NUM_PROC="1"
export DEFAULT_TOKENIZE_BATCH_SIZE="128"
export DEFAULT_EVAL_RATIO="0.01"
export DEFAULT_SEED="42"
export DEFAULT_MIN_CHARS="1000"
export DEFAULT_PER_DEVICE_TRAIN_BATCH_SIZE="1"
export DEFAULT_GRADIENT_ACCUMULATION_STEPS="32"
export DEFAULT_NUM_TRAIN_EPOCHS="1.0"
export DEFAULT_LEARNING_RATE="2e-4"
export DEFAULT_WEIGHT_DECAY="0.01"
export DEFAULT_LR_SCHEDULER_TYPE="cosine"
export DEFAULT_PER_DEVICE_EVAL_BATCH_SIZE="1"
export DEFAULT_TRAIN_LAST_N_LAYERS="1"
export DEFAULT_TRAIN_LM_HEAD="0"
export DEFAULT_DTYPE="bf16"
export DEFAULT_ATTENTION="sdpa"
export DEFAULT_DEVICE_MAP="single"
export DEFAULT_MAX_MEMORY="3GiB"
export DEFAULT_CPU_MEMORY="32GiB"
export DEFAULT_OPTIM="adafactor"
export DEFAULT_MAX_GRAD_NORM="0"
export DEFAULT_FLOAT32_MATMUL_PRECISION="high"
export DEFAULT_LORA_RANK="16"
export DEFAULT_LOGGING_STEPS="1"
export DEFAULT_SAVE_STEPS="100"
export DEFAULT_SAVE_TOTAL_LIMIT="3"
export DEFAULT_WARMUP_RATIO="0.03"
export DEFAULT_DATALOADER_NUM_WORKERS="4"

export CONTINUED_PRETRAIN_MAX_MEMORY="3GiB"
export CONTINUED_PRETRAIN_ATTENTION="sdpa"
export CONTINUED_PRETRAIN_OPTIM="adafactor"
export CONTINUED_PRETRAIN_MXFP4_DEQUANTIZE="0"

export START_MARKERS="START OF THE QUESTION"
export END_MARKERS="END OF THE QUESTION"
export SYSTEM_PROMPT_FILE="prompt_engineer.txt"
# SYSTEM_PROMPT is still supported as a fallback when SYSTEM_PROMPT_FILE is unset.
# export SYSTEM_PROMPT="identify the source of the question and answer the question based on the context provided."
export HF_TOKEN=""
