# Copy to .env.container and edit for container runs.
# The docker/run.zsh helper mounts DATA_DIR at /datasets and CACHE_DIR at
# /cache/huggingface, so container paths should usually stay under /datasets.

RAWTEXT_DIR=/datasets/raw-text
RAW_TEXT_DIR=/datasets/raw-text
TEXT_DIR=/datasets/raw-text
PDF_DIR=/datasets/pdfs

MODEL_ROOT=/datasets/model_root
PREPARED_DIR=/datasets/model_root/prepared
RAG_DIR=/datasets/model_root/rag
MODEL_DIR=/datasets/model_root/model
CORPUS_DIR=/datasets/model_root/corpus
OUTPUT_DIR=/datasets/model_root/model

TRAIN_FILE=/datasets/model_root/corpus/train.jsonl
LORA_DIR=/datasets/model_root/model/lora
ADAPTER_DIR=/datasets/model_root/model/lora/final

EMBED_MODEL=BAAI/bge-base-en-v1.5
RERANKER_MODEL=BAAI/bge-reranker-v2-m3
GENERATOR_MODEL=Qwen/Qwen2.5-3B-Instruct
BASE_MODEL=Qwen/Qwen2.5-3B-Instruct

HF_HOME=/cache/huggingface
TRANSFORMERS_CACHE=/cache/huggingface/transformers
HF_DATASETS_CACHE=/cache/huggingface/datasets

# Set this at runtime or in your shell when needed. Avoid committing tokens.
HF_TOKEN=

# AMD/ROCm hosts may need these:
HSA_OVERRIDE_GFX_VERSION=11.0.0
TORCH_ROCM_AOTRITON_ENABLE_EXPERIMENTAL=1
