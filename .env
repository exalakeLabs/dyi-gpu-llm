## GPU ENGINE - AMD specific
export HSA_OVERRIDE_GFX_VERSION=11.0.0
export TORCH_ROCM_AOTRITON_ENABLE_EXPERIMENTAL=1

## Dataset directories (absolute, or relative to repo root)
export RAWTEXT_DIR="/datasets/raw-text"
export RAW_TEXT_DIR=${RAWTEXT_DIR}
export TEXT_DIR=${RAWTEXT_DIR}
export PDF_DIR=/datasets/pdfs

## Corpus / pipeline directories (absolute, or relative to repo root)
export MODEL_ROOT="/datasets/model_root"
export PREPARED_DIR=${MODEL_ROOT}/prepared
export RAG_DIR=${MODEL_ROOT}/rag
export MODEL_DIR=${MODEL_ROOT}/model
export CORPUS_DIR=${MODEL_ROOT}/corpus
export OUTPUT_DIR=${MODEL_DIR}

#MODELS
export EMBED_MODEL=BAAI/bge-base-en-v1.5
export RERANKER_MODEL=BAAI/bge-reranker-v2-m3
export GENERATOR_MODEL=Qwen/Qwen2.5-7B-Instruct
export BASE_MODEL=${GENERATOR_MODEL}

#RAG parameters
export OVERLAP_CHARS=250
export CHUNK_SIZE_CHARS=1800
export BATCH_SIZE=32

#LoRA training parameters
export RETRIEVE_K=24
export RERANK_TOP_N=6
export MAX_NEW_TOKENS=500

#Training parameters
export TRAIN_FILE=${CORPUS_DIR}/train.jsonl
export LORA_DIR=${OUTPUT_DIR}/lora
export ADAPTER_DIR=${LORA_DIR}/final
export DEFAULT_MODEL=${BASE_MODEL}
export DEFAULT_MODEL_PATH=${MODEL_DIR}
export DEFAULT_BACKEND=cuda:0
export DEFAULT_TEXT_DIR=${PREPARED_DIR}
export DEFAULT_CORPUS_DIR=${CORPUS_DIR}
export DEFAULT_TRAIN_FILE=train.jsonl
export DEFAULT_EVAL_FILE=eval.jsonl
export DEFAULT_OUTPUT_DIR=${MODEL_DIR}/output_partial
export DEFAULT_MAX_LENGTH=512
export DEFAULT_SEQ_LEN=2048
export DEFAULT_DATASET_NUM_PROC=1
export DEFAULT_TOKENIZE_BATCH_SIZE=128
export DEFAULT_EVAL_RATIO=0.01
export DEFAULT_SEED=42
export DEFAULT_MIN_CHARS=1000
export DEFAULT_PER_DEVICE_TRAIN_BATCH_SIZE=1
export DEFAULT_GRADIENT_ACCUMULATION_STEPS=8
export DEFAULT_NUM_TRAIN_EPOCHS=1.0
export DEFAULT_LEARNING_RATE=2e-4
export DEFAULT_WEIGHT_DECAY=0.01
export DEFAULT_LR_SCHEDULER_TYPE=cosine
export DEFAULT_PER_DEVICE_EVAL_BATCH_SIZE=1
export DEFAULT_TRAIN_LAST_N_LAYERS=8
export DEFAULT_DTYPE=auto
export DEFAULT_ATTENTION=auto
export DEFAULT_DEVICE_MAP=auto
export DEFAULT_OPTIM=adamw_torch_fused
export DEFAULT_FLOAT32_MATMUL_PRECISION=high
export DEFAULT_LORA_RANK=16
export DEFAULT_LOGGING_STEPS=1
export DEFAULT_SAVE_STEPS=100
export DEFAULT_SAVE_TOTAL_LIMIT=3
export DEFAULT_WARMUP_RATIO=0.03
export DEFAULT_DATALOADER_NUM_WORKERS=4

export DEFAULT_SYSTEM_PROMPT="You are a careful Tolkien lore assistant. Use the retrieved canon context carefully, distinguish certainty from inference, and avoid inventing details."
export START_MARKERS="START OF THE PROJECT GUTENBERG EBOOK|START OF THIS PROJECT GUTENBERG EBOOK|*** START OF THE PROJECT GUTENBERG EBOOK|*** START OF THIS PROJECT GUTENBERG EBOOK"
export END_MARKERS="END OF THE PROJECT GUTENBERG EBOOK|END OF THIS PROJECT GUTENBERG EBOOK|*** END OF THE PROJECT GUTENBERG EBOOK|*** END OF THIS PROJECT GUTENBERG EBOOK"
export SYSTEM_PROMPT="${DEFAULT_SYSTEM_PROMPT}"
