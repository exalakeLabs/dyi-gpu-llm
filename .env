## Corpus / pipeline directories (absolute, or relative to repo root)
export MODEL_ROOT=/datasets/llbase
export LLAMA_TEXT_DIR=${MODEL_ROOT}/text
export LLAMA_PREPARED_DIR=${MODEL_ROOT}/prepared
export LLAMA_RAG_DIR=${MODEL_ROOT}/rag
export LLAMA_OUTPUT_DIR=${MODEL_ROOT}/output

## Optional
export LLAMA_DATA_DIR=${MODEL_ROOT}/data
export LLAMA_PDF_DIR=${MODEL_ROOT}/pdfs



## GPU ENGINE  
export HSA_OVERRIDE_GFX_VERSION=11.0.0
export TORCH_ROCM_AOTRITON_ENABLE_EXPERIMENTAL=1
